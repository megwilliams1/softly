  rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      function isAdmin() {
        return request.auth.uid in ['XMEkePVCnIdGJQLaCNwmidt0Ry13', 'HIZiVlL6zdRDTLxkUCeXeatDSId2'];
      }

      match /recipes/{recipeId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
      }

      // Profile doc — any signed-in user can read (needed for admin panel)
      match /users/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // Personal data subcollections — own user only
      match /users/{userId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }

